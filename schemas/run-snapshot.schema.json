{
  "$defs": {
    "AgentAnswer": {
      "additionalProperties": false,
      "description": "Final user-facing answer synthesized by the manager (FLH-F-002).",
      "properties": {
        "delivered_revision_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delivered Revision Name"
        },
        "schema_version": {
          "default": 1,
          "minimum": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "AgentAnswer",
      "type": "object"
    },
    "AssumptionRecord": {
      "additionalProperties": false,
      "description": "A manager-recorded assumption made when spec is ambiguous (FLH-F-020).",
      "properties": {
        "assumption": {
          "title": "Assumption",
          "type": "string"
        },
        "recorded_at": {
          "title": "Recorded At",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "minimum": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "topic": {
          "title": "Topic",
          "type": "string"
        }
      },
      "required": [
        "topic",
        "assumption"
      ],
      "title": "AssumptionRecord",
      "type": "object"
    },
    "ReviewDecision": {
      "enum": [
        "pass",
        "revise"
      ],
      "title": "ReviewDecision",
      "type": "string"
    },
    "SnapshotArtifacts": {
      "additionalProperties": false,
      "properties": {
        "glb_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Glb Path"
        },
        "render_sheet_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Render Sheet Path"
        },
        "schema_version": {
          "default": 1,
          "minimum": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "step_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Step Path"
        },
        "view_paths": {
          "items": {
            "type": "string"
          },
          "title": "View Paths",
          "type": "array"
        }
      },
      "title": "SnapshotArtifacts",
      "type": "object"
    }
  },
  "$id": "formloop/run-snapshot",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Materialized, polling-friendly view of current run state.",
  "properties": {
    "artifacts": {
      "$ref": "#/$defs/SnapshotArtifacts"
    },
    "assumptions": {
      "items": {
        "$ref": "#/$defs/AssumptionRecord"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "current_revision_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Current Revision Name"
    },
    "current_spec": {
      "additionalProperties": true,
      "title": "Current Spec",
      "type": "object"
    },
    "delivered_revision_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Delivered Revision Name"
    },
    "effective_role_runtimes": {
      "additionalProperties": {
        "additionalProperties": {
          "type": "string"
        },
        "type": "object"
      },
      "title": "Effective Role Runtimes",
      "type": "object"
    },
    "final_answer": {
      "anyOf": [
        {
          "$ref": "#/$defs/AgentAnswer"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "generated_at": {
      "title": "Generated At",
      "type": "string"
    },
    "input_summary": {
      "default": "",
      "title": "Input Summary",
      "type": "string"
    },
    "last_event_index": {
      "default": -1,
      "minimum": -1,
      "title": "Last Event Index",
      "type": "integer"
    },
    "last_event_kind": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Event Kind"
    },
    "last_message": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Message"
    },
    "latest_narration": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latest Narration"
    },
    "latest_narration_index": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latest Narration Index"
    },
    "latest_narration_phase": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latest Narration Phase"
    },
    "latest_review_decision": {
      "anyOf": [
        {
          "$ref": "#/$defs/ReviewDecision"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "latest_review_summary_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latest Review Summary Path"
    },
    "research_findings": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Research Findings",
      "type": "array"
    },
    "revisions": {
      "items": {
        "type": "string"
      },
      "title": "Revisions",
      "type": "array"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "run_name": {
      "title": "Run Name",
      "type": "string"
    },
    "schema_version": {
      "default": 1,
      "minimum": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "status": {
      "title": "Status",
      "type": "string"
    },
    "status_detail": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Status Detail"
    }
  },
  "required": [
    "run_id",
    "run_name",
    "status"
  ],
  "title": "RunSnapshot",
  "type": "object"
}
