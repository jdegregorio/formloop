    },
    "current_status_summary": {
      "title": "Current Status Summary",
      "type": "string"
    },
    "effective_model": {
      "title": "Effective Model",
      "type": "string"
    },
    "effective_profile": {
      "title": "Effective Profile",
      "type": "string"
    },
    "effective_reasoning": {
      "title": "Effective Reasoning",
      "type": "string"
    },
    "input_summary": {
      "title": "Input Summary",
      "type": "string"
    },
    "progress_events": {
      "items": {
        "type": "string"
      },
      "title": "Progress Events",
      "type": "array"
    },
    "prompt": {
      "title": "Prompt",
      "type": "string"
    },
    "reference_image": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reference Image"
    },
    "research_findings": {
      "items": {
        "$ref": "#/$defs/ResearchFinding"
      },
      "title": "Research Findings",
      "type": "array"
    },
    "review_outputs": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Review Outputs",
      "type": "object"
    },
    "revisions": {
      "items": {
        "$ref": "#/$defs/RevisionRecord"
      },
      "title": "Revisions",
      "type": "array"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "run_name": {
      "title": "Run Name",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/RunStatus",
      "default": "created"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
