{
  "$defs": {
    "ChecklistCategory": {
      "enum": [
        "primitive",
        "subtracted",
        "added",
        "edge_treatment",
        "pattern",
        "thread_gear_spline",
        "other"
      ],
      "title": "ChecklistCategory",
      "type": "string"
    },
    "ChecklistItem": {
      "additionalProperties": false,
      "description": "One row of the reviewer's spec-derived feature checklist.\n\nThe reviewer enumerates every feature called out by the spec \u2014 overall\nprimitive + dimensions, subtracted features, added features, edge\ntreatments, patterns, and any thread / gear / spline features \u2014 and\nproduces one ``ChecklistItem`` per feature with a verdict backed by either\nthe rendered views, the inspect summary, or both.",
      "properties": {
        "category": {
          "$ref": "#/$defs/ChecklistCategory"
        },
        "expected": {
          "description": "What the spec calls for, in the reviewer's words.",
          "title": "Expected",
          "type": "string"
        },
        "feature": {
          "description": "Short label identifying the feature.",
          "title": "Feature",
          "type": "string"
        },
        "method": {
          "$ref": "#/$defs/ChecklistMethod"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "observed": {
          "default": "",
          "description": "What the reviewer actually saw in the renderings or inspect summary.",
          "title": "Observed",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "minimum": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "verdict": {
          "$ref": "#/$defs/ChecklistVerdict"
        }
      },
      "required": [
        "feature",
        "category",
        "expected",
        "method",
        "verdict"
      ],
      "title": "ChecklistItem",
      "type": "object"
    },
    "ChecklistMethod": {
      "enum": [
        "visual",
        "inspect",
        "both",
        "unverified"
      ],
      "title": "ChecklistMethod",
      "type": "string"
    },
    "ChecklistVerdict": {
      "enum": [
        "pass",
        "fail",
        "unverified"
      ],
      "title": "ChecklistVerdict",
      "type": "string"
    }
  },
  "$id": "formloop/judge-output",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Quality Specialist judgment in eval mode.",
  "properties": {
    "case_id": {
      "title": "Case Id",
      "type": "string"
    },
    "dimension_scores": {
      "additionalProperties": {
        "type": "number"
      },
      "description": "Per-dimension 0..1 scores (e.g. geometric_accuracy, feature_presence).",
      "title": "Dimension Scores",
      "type": "object"
    },
    "feature_checklist": {
      "description": "One row per spec feature; backs the dimension scores.",
      "items": {
        "$ref": "#/$defs/ChecklistItem"
      },
      "title": "Feature Checklist",
      "type": "array"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "title": "Notes",
      "type": "array"
    },
    "overall_score": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Overall Score",
      "type": "number"
    },
    "pass": {
      "title": "Pass",
      "type": "boolean"
    },
    "rationale": {
      "title": "Rationale",
      "type": "string"
    },
    "schema_version": {
      "default": 1,
      "minimum": 1,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "required": [
    "case_id",
    "overall_score",
    "pass",
    "rationale"
  ],
  "title": "JudgeOutput",
  "type": "object"
}
