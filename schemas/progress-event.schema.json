{
  "$defs": {
    "ProgressEventKind": {
      "enum": [
        "run_created",
        "spec_normalized",
        "assumption_recorded",
        "research_started",
        "research_completed",
        "revision_started",
        "revision_planned",
        "revision_built",
        "revision_rendered",
        "revision_persisted",
        "review_started",
        "review_completed",
        "breadcrumb",
        "narration",
        "delivered",
        "run_failed"
      ],
      "title": "ProgressEventKind",
      "type": "string"
    }
  },
  "$id": "formloop/progress-event",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "One append-only progress event.\n\n``message`` is human-friendly text. For ``kind == narration`` it is the\nLLM-written conversational status update (FLH-F-026); the orchestrator\nfalls back to a static string when the Narrator agent fails. ``data``\ncarries structured per-kind payload (e.g. ``phase``, ``signals``,\n``narration_error``).",
  "properties": {
    "data": {
      "additionalProperties": true,
      "title": "Data",
      "type": "object"
    },
    "index": {
      "description": "Zero-based ordinal within the run.",
      "minimum": 0,
      "title": "Index",
      "type": "integer"
    },
    "kind": {
      "$ref": "#/$defs/ProgressEventKind"
    },
    "message": {
      "default": "",
      "title": "Message",
      "type": "string"
    },
    "narration_error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Populated on narration events when the Narrator agent failed and the static fallback message was substituted (FLH-NF-010).",
      "title": "Narration Error"
    },
    "phase": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Coarse phase tag (plan/research/revision/review/final/failure). Always set for narration events; optional for milestone events.",
      "title": "Phase"
    },
    "schema_version": {
      "default": 1,
      "minimum": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "ts": {
      "title": "Ts",
      "type": "string"
    }
  },
  "required": [
    "index",
    "kind"
  ],
  "title": "ProgressEvent",
  "type": "object"
}
